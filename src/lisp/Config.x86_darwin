# -*- Mode: makefile -*-

include Config.x86_common

# Stock clang (and cc) on MacOS doesn't compile openlibm to handle FP
# exceptions the way we want.  Exceptions aren't signaled.
#
# Instead, use MacPorts to get more recent versions of the compilers.
# We currently use clang 14.0.6 and gcc 12.1.0.  With these compilers,
# openlibm is compiled correctly to signal the desired FP exceptions.
#
# The unit tests pass and so do the ansi-tests.

#CC = /opt/local/bin/clang -ftrapping-math
CC = /opt/local/bin/gcc

# Compile code that will run on OSX 10.6.  This only works if
# you have the SDK available.
MIN_VER = -mmacosx-version-min=10.6

CFLAGS += $(COPT)
CPPFLAGS += -DDARWIN $(MIN_VER) -m32
CFLAGS += -g3 -mtune=generic
ASFLAGS += -g3 $(MIN_VER)


UNDEFSYMPATTERN = -Xlinker -u -Xlinker &

OS_SRC += Darwin-os.c mach-o.c

# Turn off the PIE warning; we know the x86-assem.S is not
# relocatable, and we're not going to fix that anytime soon.
OS_LINK_FLAGS = -m32 $(MIN_VER) -Wl,-no_pie
OS_LIBS =

EXEC_FINAL_OBJ = exec-final.o
